{
  "buildCommand": "uv pip install -r requirements.txt",
  "installCommand": "uv pip install -r requirements.txt",
  "env": {
    "PYTHONUNBUFFERED": "1"
  },
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "/api/index.py"
    }
  ]
}
